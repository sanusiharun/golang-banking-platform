# ─────────────────────────────────────────────────────────────────────────────
# datasource/.env.example — Banking Platform Datasource Layer
#
# Used by: datasource/docker-compose.yml (if running Postgres via Docker)
#
# If you use Docker Desktop's built-in Postgres, you don't need this file.
# The root .env handles all service-level credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

# ── MongoDB (if used in future) ───────────────────────────────────────────────
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=
MONGO_DATABASE=banking
