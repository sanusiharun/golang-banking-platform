# ─────────────────────────────────────────────────────────────────────────────
# Banking Platform — Root Environment File
#
# Used by:  docker-compose.yml        (microservices)
#           docker-compose.infra.yml  (observability stack)
#
# Setup:
#   cp .env.example .env
#   # fill in real values, especially JWT keys and DB passwords
#
# ⚠️  Never commit .env — it is gitignored.
#     This .env.example is the safe committed version.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by auth-svc (banking_auth) and account-svc (banking_accounts).
# Each service has its own DB user — no cross-service DB access.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432

AUTH_DB_NAME=banking_auth
AUTH_DB_USER=auth_svc
AUTH_DB_PASSWORD=

ACCOUNT_DB_NAME=banking_accounts
ACCOUNT_DB_USER=account_svc
ACCOUNT_DB_PASSWORD=

# ── JWT — RS256 keypair ───────────────────────────────────────────────────────
# Generate a fresh keypair:
#   openssl genrsa -out private.pem 2048
#   openssl pkcs8 -topk8 -nocrypt -in private.pem -out private_pkcs8.pem
#   openssl rsa -in private.pem -pubout -out public.pem
#   base64 -w0 private_pkcs8.pem   # → JWT_PRIVATE_KEY_B64
#   base64 -w0 public.pem          # → JWT_PUBLIC_KEY_B64
#
# auth-svc holds the PRIVATE key (signs tokens).
# All other services hold the PUBLIC key (verify tokens only).
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=
JWT_ISSUER=banking-platform
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# When running via docker-compose, services reach Jaeger by container name.
# When running locally (make run-*), use localhost:4317 in service .env files.
OTEL_ENABLED=true
OTEL_LOGS_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4317
OTEL_SAMPLING_RATE=1.0

# ── Rate limiting (account-svc) ───────────────────────────────────────────────
RATE_LIMIT_RPS=1000
RATE_LIMIT_BURST=2000

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── Alertmanager ─────────────────────────────────────────────────────────────
# Set to a real Slack webhook or email SMTP in staging/production.
ALERTMANAGER_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Discord Alerts ───────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
