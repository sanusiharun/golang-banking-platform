# ─────────────────────────────────────────────────────────────────────────────
# auth-svc — local development environment
# Copy to .env and fill in real values.
# ⚠️  Never commit the real .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Service identity ──────────────────────────────────────────────────────────
SERVICE_NAME=auth-svc
SERVICE_VERSION=0.1.0
ENVIRONMENT=local

# ── HTTP server ───────────────────────────────────────────────────────────────
HTTP_PORT=8080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
AUTH_DB_NAME=banking_auth
AUTH_DB_USER=auth_svc
AUTH_DB_PASSWORD=your_password_here

# ── JWT — RS256 (auth-svc holds BOTH keys: signs + verifies) ─────────────────
# Generate with: make gen-keys
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=
JWT_ISSUER=banking-platform
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_LOGS_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_SAMPLING_RATE=1.0

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPS=500
RATE_LIMIT_BURST=1000
