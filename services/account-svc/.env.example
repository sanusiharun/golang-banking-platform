# ─────────────────────────────────────────────────────────────────────────────
# account-svc — local development environment
# Copy to .env and fill in real values.
# ⚠️  Never commit the real .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Service identity ──────────────────────────────────────────────────────────
SERVICE_NAME=account-svc
SERVICE_VERSION=0.1.0
ENVIRONMENT=local

# ── HTTP server ───────────────────────────────────────────────────────────────
HTTP_PORT=8081

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
ACCOUNT_DB_NAME=banking_accounts
ACCOUNT_DB_USER=account_svc
ACCOUNT_DB_PASSWORD=your_password_here

# ── JWT — RS256 (account-svc holds PUBLIC key ONLY for token verification) ────
# Copy JWT_PUBLIC_KEY_B64 from auth-svc — they must match
JWT_PUBLIC_KEY_B64=
JWT_ISSUER=banking-platform

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_LOGS_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_SAMPLING_RATE=1.0

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPS=1000
RATE_LIMIT_BURST=2000
